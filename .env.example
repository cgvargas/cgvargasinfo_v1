SECRET_KEY=sua-secret-key-aqui-gerada-com-python-secrets
DEBUG=True

# Supabase PostgreSQL — copie a "Transaction pooler" connection string do Supabase
DATABASE_URL=postgresql://postgres:[password]@[host]:5432/postgres

# Cloudinary — copie do dashboard em cloudinary.com
CLOUDINARY_CLOUD_NAME=seu-cloud-name
CLOUDINARY_API_KEY=sua-api-key
CLOUDINARY_API_SECRET=seu-api-secret

# Hosts permitidos (em produção coloque seu domínio)
ALLOWED_HOSTS=localhost,127.0.0.1,cgvargas.onrender.com,cgvargas.com.br

# Email para formulário de contato
EMAIL_HOST_USER=cgvargas.inf@outlook.com
EMAIL_HOST_PASSWORD=senha-do-email
